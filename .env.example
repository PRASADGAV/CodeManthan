# CodeManthan Environment Variables
# Copy this file to .env and fill in your values

# Claude API Key (Anthropic) - for AI Topic Explainer & Adaptive Learning Path
# Get your key from: https://console.anthropic.com/
# Leave empty to use built-in fallback explanations
VITE_CLAUDE_API_KEY=

# Gemini API Key - for PDF to Quiz Generation and personalized onboarding quiz (10 questions from domains + keywords)
# Get your key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
